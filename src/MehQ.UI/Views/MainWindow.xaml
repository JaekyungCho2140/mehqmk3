<Fluent:RibbonWindow x:Class="MehQ.UI.Views.MainWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:Fluent="urn:fluent-ribbon"
                     xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
                     xmlns:vm="clr-namespace:MehQ.UI.ViewModels"
                     xmlns:views="clr-namespace:MehQ.UI.Views"
                     Title="mehQ — Computer-Assisted Translation"
                     Width="1280" Height="800"
                     WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Ribbon Menu -->
        <Fluent:Ribbon Grid.Row="0">
            <!-- Backstage (memoQ application menu) -->
            <Fluent:Ribbon.Menu>
                <Fluent:Backstage Header="memoQ">
                    <Fluent:BackstageTabControl>
                        <Fluent:BackstageTabItem Header="New Project" />
                        <Fluent:BackstageTabItem Header="Open Project" />
                        <Fluent:BackstageTabItem Header="Recent Projects" />
                        <Fluent:SeparatorTabItem />
                        <Fluent:BackstageTabItem Header="Settings" />
                        <Fluent:BackstageTabItem Header="About mehQ" />
                    </Fluent:BackstageTabControl>
                </Fluent:Backstage>
            </Fluent:Ribbon.Menu>

            <!-- Project Tab -->
            <Fluent:RibbonTabItem Header="Project">
                <Fluent:RibbonGroupBox Header="Project">
                    <Fluent:Button Header="New"
                                   Command="{Binding CreateProjectCommand}"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Open"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Close"
                                   SizeDefinition="Large" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Import/Export">
                    <Fluent:Button Header="Import"
                                   Command="{Binding EditorViewModel.OpenDocumentCommand}"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Export"
                                   Command="{Binding EditorViewModel.SaveDocumentCommand}"
                                   SizeDefinition="Large" />
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- Documents Tab -->
            <Fluent:RibbonTabItem Header="Documents">
                <Fluent:RibbonGroupBox Header="Documents">
                    <Fluent:Button Header="Import"
                                   Command="{Binding EditorViewModel.OpenDocumentCommand}"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Translate"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Export"
                                   Command="{Binding EditorViewModel.SaveDocumentCommand}"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Remove"
                                   SizeDefinition="Large" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Reimport/Review">
                    <Fluent:Button Header="Reimport"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="X-Translate"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Monolingual Review"
                                   SizeDefinition="Middle" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Statistics">
                    <Fluent:Button Header="Statistics"
                                   SizeDefinition="Large" />
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- Preparation Tab -->
            <Fluent:RibbonTabItem Header="Preparation">
                <Fluent:RibbonGroupBox Header="Pre-Translation">
                    <Fluent:Button Header="Pre-Translate"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Confirm/Update"
                                   SizeDefinition="Large" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Operations">
                    <Fluent:Button Header="Run QA"
                                   Command="{Binding EditorViewModel.RunQaCommand}"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Copy Source"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Pseudo-Translate"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Export Bilingual"
                                   SizeDefinition="Middle" />
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- View Tab -->
            <Fluent:RibbonTabItem Header="View">
                <Fluent:RibbonGroupBox Header="Layout">
                    <Fluent:Button Header="Default Layout"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Results on Top"
                                   SizeDefinition="Middle" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Panels">
                    <Fluent:Button Header="Project Home"
                                   SizeDefinition="Large" />
                    <Fluent:ToggleButton Header="View Pane"
                                         SizeDefinition="Large" />
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- Workflow Tab -->
            <Fluent:RibbonTabItem Header="Workflow">
                <Fluent:RibbonGroupBox Header="Workflow">
                    <Fluent:Button Header="Assign"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Deliver"
                                   SizeDefinition="Large" />
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- Translation Contextual Tab (visible when editor is open) -->
            <Fluent:RibbonTabItem Header="Translation" Group="{Binding ElementName=TranslationContextualGroup}">
                <Fluent:RibbonGroupBox Header="Segment">
                    <Fluent:Button Header="Edit Source"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Revert Source"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Lock/Unlock"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Scan Segment"
                                   SizeDefinition="Middle" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Translation Hits">
                    <Fluent:Button Header="Insert Selected Hit"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Change Current Hit"
                                   SizeDefinition="Middle" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Search">
                    <Fluent:Button Header="Concordance"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Look Up Term"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Web Search"
                                   SizeDefinition="Middle" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Store">
                    <Fluent:Button Header="Confirm"
                                   Command="{Binding EditorViewModel.ConfirmSegmentCommand}"
                                   SizeDefinition="Large" />
                    <Fluent:Button Header="Add Term"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Quick Add Term"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Add Non-Translatable"
                                   SizeDefinition="Middle" />
                </Fluent:RibbonGroupBox>
                <Fluent:RibbonGroupBox Header="Comments And Proofing">
                    <Fluent:Button Header="Mark Text"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Comments"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Spelling/Grammar"
                                   SizeDefinition="Middle" />
                    <Fluent:Button Header="Errors And Warnings"
                                   SizeDefinition="Middle" />
                </Fluent:RibbonGroupBox>
            </Fluent:RibbonTabItem>

            <!-- Contextual Tab Groups -->
            <Fluent:Ribbon.ContextualGroups>
                <Fluent:RibbonContextualTabGroup x:Name="TranslationContextualGroup"
                                                  Header="Translation Editor"
                                                  Visibility="Collapsed"
                                                  Background="#FF2B579A"
                                                  BorderBrush="#FF2B579A" />
            </Fluent:Ribbon.ContextualGroups>
        </Fluent:Ribbon>

        <!-- Main Content Area with AvalonDock -->
        <avalonDock:DockingManager Grid.Row="1" x:Name="DockManager">
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Vertical">
                    <avalonDock:LayoutPanel Orientation="Horizontal">
                        <!-- Center: Document pane (Translation Editor) -->
                        <avalonDock:LayoutDocumentPane>
                            <avalonDock:LayoutDocument Title="Dashboard" CanClose="False">
                                <ContentControl Content="{Binding CurrentView}" />
                            </avalonDock:LayoutDocument>
                            <avalonDock:LayoutDocument Title="Translation Editor" CanClose="False">
                                <views:TranslationEditorView DataContext="{Binding EditorViewModel}" />
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>

                        <!-- Right: Translation Results -->
                        <avalonDock:LayoutAnchorablePane DockWidth="320">
                            <avalonDock:LayoutAnchorable Title="Translation Results"
                                                         CanClose="False"
                                                         CanHide="False"
                                                         AutoHideWidth="320">
                                <Grid DataContext="{Binding EditorViewModel}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- TM Matches -->
                                    <TextBlock Grid.Row="0" Text="TM Matches" FontWeight="SemiBold" Padding="8,4" Background="#F5F5F5" />
                                    <ListBox Grid.Row="1" ItemsSource="{Binding TmMatches}" BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4,2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#E53935" CornerRadius="2" Padding="4,1" Margin="0,0,6,0">
                                                            <TextBlock Text="{Binding MatchRate, StringFormat={}{0}%}" Foreground="White" FontSize="11" FontWeight="Bold" />
                                                        </Border>
                                                        <TextBlock Text="{Binding Entry.Source}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Entry.Target}" FontSize="12" Foreground="#1565C0" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- TB Matches -->
                                    <TextBlock Grid.Row="2" Text="Term Base" FontWeight="SemiBold" Padding="8,4" Background="#F5F5F5" />
                                    <ListBox Grid.Row="3" ItemsSource="{Binding TermMatches}" BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                                    <Border Background="#1565C0" CornerRadius="2" Padding="4,1" Margin="0,0,6,0">
                                                        <TextBlock Text="TB" Foreground="White" FontSize="10" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Term.SourceTerm}" FontSize="12" Margin="0,0,8,0" />
                                                    <TextBlock Text="&#x2192;" Foreground="Gray" Margin="0,0,8,0" />
                                                    <TextBlock Text="{Binding Term.TargetTerm}" FontSize="12" Foreground="#1565C0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </avalonDock:LayoutAnchorable>
                        </avalonDock:LayoutAnchorablePane>
                    </avalonDock:LayoutPanel>

                    <!-- Bottom: View Pane -->
                    <avalonDock:LayoutAnchorablePane DockHeight="200">
                        <avalonDock:LayoutAnchorable Title="View"
                                                     CanClose="False"
                                                     CanHide="True"
                                                     AutoHideHeight="200">
                            <Grid DataContext="{Binding EditorViewModel}">
                                <TabControl>
                                    <TabItem Header="QA Warnings">
                                        <DataGrid ItemsSource="{Binding QaWarnings}" AutoGenerateColumns="False"
                                                  IsReadOnly="True" BorderThickness="0" GridLinesVisibility="Horizontal"
                                                  HorizontalGridLinesBrush="#E0E0E0">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="#" Width="40" Binding="{Binding SequenceNumber}" />
                                                <DataGridTextColumn Header="Severity" Width="70" Binding="{Binding Severity}" />
                                                <DataGridTextColumn Header="Category" Width="120" Binding="{Binding Category}" />
                                                <DataGridTextColumn Header="Code" Width="70" Binding="{Binding Code}" />
                                                <DataGridTextColumn Header="Message" Width="*" Binding="{Binding Message}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="Preview">
                                        <TextBlock Text="Document preview will appear here" Padding="10" Foreground="Gray"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>
                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#F0F0F0">
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Doc: " Foreground="Gray" />
                    <Run Text="{Binding EditorViewModel.CompletionPercentage, Mode=OneWay, FallbackValue='--'}" />
                    <Run Text="%" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Text="TR: " Foreground="#4CAF50" />
                    <Run Text="{Binding EditorViewModel.ConfirmedSegments, Mode=OneWay, FallbackValue='0'}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Ed: " Foreground="#FF9800" />
                    <Run Text="{Binding EditorViewModel.EditedSegments, Mode=OneWay, FallbackValue='0'}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Empty: " Foreground="Gray" />
                    <Run Text="{Binding EditorViewModel.EmptySegments, Mode=OneWay, FallbackValue='0'}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Pre: " Foreground="#2196F3" />
                    <Run Text="{Binding EditorViewModel.PreTranslatedSegments, Mode=OneWay, FallbackValue='0'}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Total: " Foreground="Gray" />
                    <Run Text="{Binding EditorViewModel.TotalSegments, Mode=OneWay, FallbackValue='0'}" />
                </TextBlock>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="mehQ v0.1.0" Foreground="Gray" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Fluent:RibbonWindow>
