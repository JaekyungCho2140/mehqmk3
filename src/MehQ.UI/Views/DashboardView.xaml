<UserControl x:Class="MehQ.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="mehQ"
                       FontSize="32" FontWeight="Bold"
                       Foreground="#2B579A" />
            <TextBlock Text="Computer-Assisted Translation Tool"
                       FontSize="14" Foreground="Gray" Margin="0,5,0,0" />
        </StackPanel>

        <!-- Quick Actions -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="New Project" Padding="15,8" Margin="0,0,10,0"
                    Background="#2B579A" Foreground="White" BorderThickness="0"
                    Command="{Binding DataContext.CreateProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
            <Button Content="Open Project" Padding="15,8" Margin="0,0,10,0" />
        </StackPanel>

        <!-- Recent Projects List -->
        <GroupBox Grid.Row="2" Header="Recent Projects" Padding="10">
            <ListView ItemsSource="{Binding DataContext.RecentProjects, RelativeSource={RelativeSource AncestorType=Window}}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Name" Width="250"
                                        DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="Source" Width="100"
                                        DisplayMemberBinding="{Binding SourceLanguage}" />
                        <GridViewColumn Header="Target" Width="100"
                                        DisplayMemberBinding="{Binding TargetLanguage}" />
                        <GridViewColumn Header="Last Modified" Width="150"
                                        DisplayMemberBinding="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>
    </Grid>
</UserControl>
